# ============================================================
# Manivtha AI Trip Narrative Generator — Environment Variables
# ============================================================
# 1. Copy this file to .env
# 2. Fill in the values below
# 3. Never commit .env to git!

# ----- Server -----
PORT=3001
NODE_ENV=development

# ----- Google Gemini AI -----
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ----- MongoDB Atlas -----
# Primary persistent database
# Get your connection string from: MongoDB Atlas → Connect → Drivers
MONGODB_URI=your_mongodb_connection_string
MONGODB_DB_NAME=ainarrative

# ----- Firebase Admin SDK -----
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key"
# 3. Save the JSON file as firebase-service-account.json in the backend/ folder
# 4. Set the path below
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ----- Admin Access -----
# Comma-separated list of emails allowed to access the Admin dashboard
# Example: admin@manivtha.com,manager@manivtha.com
ADMIN_EMAILS=admin@manivtha.com

# ----- Database (Legacy SQLite — no longer used) -----
# DB_PATH=./db/trips.db
